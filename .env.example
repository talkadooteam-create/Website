# ─────────────────────────────────────────────────────────
# Talkadoo waitlist — Supabase (EU region) credentials
# Copy this file to .env.local and fill in your real values.
# Both are PUBLIC/publishable keys and safe for the browser.
# The waitlist form writes to the `waitlist` table (see supabase/waitlist.sql).
# Until these are set, the form stays usable but reports a clear
# "not connected yet" message instead of faking success.
# ─────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
